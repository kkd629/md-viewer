{
  "name": "md-viewer",
  "version": "1.6.0",
  "description": "옵시디언 스타일 마크다운 뷰어/에디터 (Windows)",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --outfile=renderer/bundle.js --format=iife --loader:.css=text",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "author": "MD Viewer",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "marked": "^14.1.3",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1"
  },
  "build": {
    "appId": "com.local.mdviewer",
    "productName": "MD Viewer",
    "asar": false,
    "electronLanguages": [
      "en-US",
      "ko"
    ],
    "files": [
      "main.js",
      "preload.js",
      "home.md",
      "renderer/**/*",
      "!renderer/SamsungOneKorean600.woff2",
      "!node_modules/**/*",
      "!src/**/*",
      "!dist/**/*",
      "!.claude/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MD Viewer",
      "artifactName": "MD Viewer Setup.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
